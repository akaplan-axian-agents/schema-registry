{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "coverageAnalysis": "off",
  "mutate": ["src/**/*.js", "!src/server.js", "!src/types.js"],
  "packageManager": "npm",
  "reporters": ["progress", "clear-text", "html"],
  "tap": {
    "forceBail": true,
    "testFiles": ["test/**/*.js"]
  },
  "testRunner": "tap",
  "thresholds": {
    "break": 75,
    "high": 80,
    "low": 75
  }
}
