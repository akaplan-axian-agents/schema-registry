{
  "name": "schema-registry",
  "version": "0.1.7",
  "private": true,
  "type": "module",
  "description": "Server-rendered JSON Schema hosting and management website with no browser JavaScript.",
  "scripts": {
    "start": "node src/server.js",
    "test": "node --test",
    "coverage": "node --test --experimental-test-coverage --test-coverage-include='src/**/*.js' --test-coverage-branches=95 --test-coverage-functions=98 --test-coverage-lines=99",
    "mutation": "stryker run",
    "format:check": "prettier \"**/*.{css,js,json,md,yml,yaml}\" --check",
    "format:fix": "prettier \"**/*.{css,js,json,md,yml,yaml}\" --write",
    "deps:check": "knip",
    "deps:fix": "knip --fix && npm install --package-lock-only --ignore-scripts",
    "lint": "eslint .",
    "security:audit": "npm audit --audit-level=high",
    "security:secrets": "secretlint \"**/*\" \".github/**/*\"",
    "check:source": "npm run format:check && npm run deps:check",
    "fix:source": "npm run format:fix && npm run deps:fix",
    "check:inspect": "npm run lint && npm run security:audit && npm run security:secrets",
    "verify": "npm run check:source && npm run check:inspect && npm run coverage && npm run mutation"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-handlebars": "^9.0.1",
    "i18next": "^26.2.0",
    "i18next-fs-backend": "^2.6.5",
    "i18next-http-middleware": "^3.9.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/tap-runner": "^9.6.1",
    "eslint": "^10.4.1",
    "knip": "^6.15.0",
    "prettier": "^3.8.3",
    "secretlint": "^13.0.2"
  }
}
